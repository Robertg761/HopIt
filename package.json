{
  "name": "hopit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "hop": "./packages/agent/src/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run build:core",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "pretest": "npm run build:core",
    "test": "npm run agent:test",
    "pretest:web": "npm run build:core",
    "test:web": "vitest run --dir src --exclude \"**/*.test.js\"",
    "test:worker": "node --test cloudflare/d1/api-worker.test.js",
    "test:config": "node --test scripts/check-production-config.test.js",
    "test:all": "npm run agent:test && npm run test:web && npm run test:worker && npm run test:config",
    "build:core": "npm run build --workspace @hopit/core",
    "pretypecheck": "npm run build:core",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace @hopit/core",
    "typecheck:agent": "tsc -p tsconfig.agent.json",
    "verify": "npm run check:copy-style && npm run lint && npm run typecheck && npm run typecheck:agent && npm run test:all && npm run build",
    "verify:release": "npm run verify && npm run package:hop -- --target all",
    "hop": "node packages/agent/src/cli.js",
    "hop:service:start": "node packages/agent/src/cli.js service start --profile production",
    "hop:service:run": "node packages/agent/src/cli.js service run --profile production",
    "hop:service:status": "node packages/agent/src/cli.js service status --profile production",
    "hop:service:stop": "node packages/agent/src/cli.js service stop --profile production",
    "hop:service:restart": "node packages/agent/src/cli.js service restart --profile production",
    "hop:backup": "node packages/agent/src/cli.js backup --profile production",
    "hop:export": "node packages/agent/src/cli.js export --profile production",
    "hop:private-export": "node packages/agent/src/cli.js export --profile production --include-private",
    "hop:publish": "node packages/agent/src/cli.js publish --profile production",
    "actions:run-once": "node packages/actions-runner/src/runner.js run-once",
    "actions:runner": "node packages/actions-runner/src/runner.js loop",
    "check:production-config": "node scripts/check-production-config.mjs",
    "check:public-site": "node scripts/check-public-site.mjs",
    "check:copy-style": "node scripts/check-copy-style.mjs",
    "package:hop": "node scripts/package-hop.mjs",
    "package:hop:dmg": "node scripts/package-hop-dmg.mjs",
    "prerelease:hop": "npm run build:core",
    "release:hop": "node scripts/release-hop.mjs",
    "release:desktop": "node scripts/release-hop.mjs --desktop-only",
    "d1:migrate:convex-export": "node scripts/migrate-convex-export-to-d1.mjs",
    "agent:demo": "node packages/agent/src/cli.js demo",
    "agent:import": "node packages/agent/src/cli.js import",
    "agent:import-git-url": "node packages/agent/src/cli.js import-git-url",
    "agent:init": "node packages/agent/src/cli.js init",
    "agent:hydrate": "node packages/agent/src/cli.js hydrate",
    "agent:refresh": "node packages/agent/src/cli.js refresh",
    "agent:sync": "node packages/agent/src/cli.js sync",
    "agent:recover": "node packages/agent/src/cli.js recover",
    "agent:review": "node packages/agent/src/cli.js review",
    "agent:merge": "node packages/agent/src/cli.js merge",
    "agent:watch": "node packages/agent/src/cli.js watch",
    "agent:status": "node packages/agent/src/cli.js status",
    "agent:serve": "node packages/agent/src/cli.js serve",
    "agent:status-server": "node packages/agent/src/cli.js serve",
    "preagent:test": "npm run build:core",
    "agent:test": "HOPIT_NO_ENV_FILE=1 HOPIT_JSON=1 node --test --test-concurrency=1 packages/agent/test/*.test.js",
    "prepackage:hop": "npm run build:core",
    "desktop:dev": "npm run start --workspace @hopit/desktop",
    "desktop:icon": "node packages/desktop/scripts/generate-icon.mjs",
    "desktop:package": "npm run package --workspace @hopit/desktop",
    "test:desktop": "npm run test --workspace @hopit/desktop"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.22",
    "@hopit/backend-d1": "file:packages/backend-d1",
    "@hopit/core": "file:packages/core",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-toast": "^1.2.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^26.1.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.15",
    "ws": "8.21.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  }
}
