HOPIT_CODEBASE_ID=hopit
HOPIT_CLOUD_BACKEND=d1
HOPIT_D1_ACCOUNT_ID=replace-with-cloudflare-account-id
HOPIT_D1_DATABASE_ID=replace-with-cloudflare-d1-database-id
HOPIT_D1_API_TOKEN=replace-with-cloudflare-d1-api-token-or-hopit-d1-proxy-token
HOPIT_D1_API_BASE_URL=https://hopit-d1-api.<account-subdomain>.workers.dev
HOPIT_AUTH_PROVIDER=clerk
HOPIT_AGENT_BASE_URL=http://127.0.0.1:4785
HOPIT_AGENT_STATE_ROOT="/Users/you/Library/Application Support/HopIt/Agent"
HOPIT_WORKSPACE_ROOT="/Users/you/HopIt Workspaces"
HOPIT_WORKSPACE_INDEX="/Users/you/Library/Application Support/HopIt/Agent/workspaces.json"
HOPIT_SESSION_ID=replace-with-this-device-session-id
HOPIT_DEVICE_NAME="Your Mac"
HOPIT_AGENT_SESSION_TOKEN=replace-after-hop-session-register
HOPIT_AGENT_SESSION_CAPABILITIES=read,write,sync,watch
HOPIT_REMOTE_PULL=1
HOPIT_REMOTE_REFRESH_INTERVAL_MS=5000
HOPIT_BACKUP_ROOT=/Users/you/HopIt-Backups
HOPIT_EXPORT_ROOT=/Users/you/HopIt-Exports

# Production blob storage: D1 stores graph metadata/realtime-ish coordination,
# object storage stores file bytes.
HOPIT_BLOB_PROVIDER=r2
HOPIT_BLOB_PREFIX=production
HOPIT_BLOB_FREE_ONLY=1
HOPIT_BLOB_STORAGE_BUDGET_BYTES=8000000000
HOPIT_R2_ACCOUNT_ID=replace-with-cloudflare-account-id
HOPIT_R2_BUCKET=hopit-blobs
HOPIT_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
HOPIT_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# Optional override; default is https://$HOPIT_R2_ACCOUNT_ID.r2.cloudflarestorage.com
# HOPIT_R2_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com

# Local-only client-side encryption for routed secrets such as .private/env/.
# Do not put this key in Vercel, D1, R2, or committed files. Transfer it
# only to trusted devices that should be able to decrypt your private secrets.
# `hop keys init-device` can now provide the local secret-sync key from the
# device user-vault keyring instead of storing HOPIT_CLIENT_ENCRYPTION_KEY here.
HOPIT_CLIENT_ENCRYPTION_KEY=base64:replace-with-32-random-bytes
HOPIT_CLIENT_ENCRYPTION_SCOPE=secrets
# Optional override; by default HopIt stores per-codebase device keyrings under
# $HOPIT_AGENT_STATE_ROOT/keys/<codebaseId>.device.json with 0600 permissions.
# HOPIT_DEVICE_KEYS_PATH=/Users/you/.config/hopit/keys/hopit.device.json
# One-shot recovery export only. Do not leave this passphrase in persistent env.
# HOPIT_RECOVERY_PASSPHRASE=replace-only-when-running-hop-keys-export-recovery

# Later Backblaze B2 migration path. Keep the same HopIt blob contract and switch providers.
# HOPIT_BLOB_PROVIDER=b2
# HOPIT_B2_BUCKET=hopit-blobs
# HOPIT_B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# HOPIT_B2_REGION=us-west-004
# HOPIT_B2_KEY_ID=replace-with-b2-key-id
# HOPIT_B2_APPLICATION_KEY=replace-with-b2-application-key

# Clerk production auth for hopit.dev.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace-with-your-clerk-publishable-key
CLERK_SECRET_KEY=sk_live_replace-with-your-clerk-secret-key
CLERK_JWT_ISSUER_DOMAIN=https://clerk.hopit.dev
HOPIT_OWNER_EMAIL=you@example.com

# Service-operations margin model. Defaults match the launch pricing research;
# override these as provider costs change.
# HOPIT_MARGIN_PROVIDER_RATE=0.05
# HOPIT_MARGIN_PROVIDER_FIXED_USD=0.50
# HOPIT_MARGIN_R2_PER_GB_USD=0.015
# HOPIT_MARGIN_D1_PER_MILLION_WRITES_USD=1
# HOPIT_MARGIN_OPS_HEADROOM_PER_TENANT_USD=0.40
# HOPIT_MARGIN_PLATFORM_BASE_USD=5

# Phase 3 billing. Keep HOPIT_BILLING off until Stripe Managed Payments is
# activated, the live products use an eligible SaaS tax code, and the webhook
# endpoint is configured. Secrets belong in Vercel, never in this file.
NEXT_PUBLIC_APP_URL=https://hopit.dev
# HOPIT_BILLING=1
# STRIPE_SECRET_KEY=sk_live_replace-in-vercel
# STRIPE_WEBHOOK_SECRET=whsec_replace-in-vercel
# STRIPE_PRICE_PLUS=price_replace-with-10-usd-monthly-price
# STRIPE_PRICE_PLUS_STORAGE=price_replace-with-15-usd-monthly-price
# CRON_SECRET=replace-with-a-long-random-secret

# Multi-tenant quota defaults; all are hard server-side write caps.
# HOPIT_QUOTA_FREE_STORAGE_BYTES=2000000000
# HOPIT_QUOTA_FREE_DAILY_WRITES=2000
# HOPIT_QUOTA_PAID_STORAGE_BYTES=30000000000
# HOPIT_QUOTA_PAID_DAILY_WRITES=20000
# HOPIT_QUOTA_PLUS_STORAGE_BYTES=100000000000
# HOPIT_QUOTA_PLUS_STORAGE_DAILY_WRITES=20000

# Optional emergency fallback only. Keep unset for normal production.
# HOPIT_ALLOW_BASIC_AUTH_FALLBACK=1
# HOPIT_DASHBOARD_USERNAME=hopit
# HOPIT_DASHBOARD_PASSWORD=replace-with-a-long-random-dashboard-password
